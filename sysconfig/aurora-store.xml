<?xml version="1.0" encoding="utf-8"?>
<!--
    SystemConfig grants for Aurora Store. Lands at /product/etc/sysconfig/.
    Neither grant needs a privileged app.

    app-link: marks Aurora as a system-linked app, so PackageManager
    auto-approves all of its declared web hosts (play.google.com and
    market.android.com) as verified App Links even though the APK does not set
    android:autoVerify (DomainVerificationCollector treats every linked system
    app as needing verification). Result: Play Store web links open in Aurora by
    default instead of the browser.

    allow-in-power-save: adds Aurora to the device-idle power-save allowlist, so
    it is exempt from Doze / app-standby. This is what Settings shows as
    "Unrestricted" battery usage.
-->
<config>
    <app-link package="com.aurora.store" />
    <allow-in-power-save package="com.aurora.store" />
</config>
